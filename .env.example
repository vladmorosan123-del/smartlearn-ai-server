# ── Server AI SmartLearning — variabile de mediu ──
# Copiaza in .env (local) sau seteaza in dashboard-ul de hosting (Render).

# Cheia Gemini (Google AI Studio) — OBLIGATORIU
GEMINI_API_KEY=

# Supabase — pentru citirea materialelor (cheia publica/anon, nu e secreta)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Domeniul site-ului tau, pentru CORS (ex. https://smartlearning.ro)
# Nesetat = permite orice origine (doar pentru local/test).
CORS_ORIGIN=

# Parola pentru operatiile administrative (indexare/debug). Alege ceva secret.
ADMIN_TOKEN=

# Limita de intrebari pe minut per utilizator (optional, default 30)
RATE_MAX=30
